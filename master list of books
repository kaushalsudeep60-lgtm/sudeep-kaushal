<!DOCTYPE html>
<html>
<head>
<title>Reports - Master List of Books</title>

<style>

body{
    font-family: Arial, sans-serif;
    background:#f2f2f2;
}

.container{
    width:1000px;
    margin:40px auto;
    background:white;
    padding:20px;
    border-radius:10px;
    box-shadow:0 0 10px gray;
}

h2{
    text-align:center;
}

.menu{
    text-align:center;
    margin-bottom:20px;
}

.menu button{
    padding:10px 15px;
    margin:5px;
    border:none;
    background:#007BFF;
    color:white;
    border-radius:5px;
    cursor:pointer;
}

.content{
    display:flex;
}

.left{
    width:30%;
    padding:10px;
}

.left button{
    display:block;
    width:100%;
    padding:10px;
    margin:5px 0;
    background:#28a745;
    color:white;
    border:none;
    border-radius:5px;
}

.right{
    width:70%;
    padding:10px;
}

table{
    width:100%;
    border-collapse:collapse;
}

table, th, td{
    border:1px solid black;
}

th, td{
    padding:8px;
    text-align:center;
}

th{
    background:#e6e6e6;
}

.logout{
    text-align:center;
    margin-top:20px;
}

.logout button{
    padding:10px 20px;
    background:red;
    color:white;
    border:none;
    border-radius:5px;
}

</style>

</head>

<body>

<div class="container">

<h2>Reports</h2>

<div class="menu">
<button>Chart</button>
<button>Reports</button>
<button>Home</button>
</div>

<div class="content">

